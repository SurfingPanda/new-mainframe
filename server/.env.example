PORT=4000

# MySQL (XAMPP defaults)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=mainframe_app

# Generate a long random string in production
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# Optional — outbound email (ticket/asset notifications + password-reset links).
# Leave SMTP_HOST empty to disable: sends become logged no-ops, app still works.
# For local testing use Mailpit/MailHog (SMTP_HOST=localhost SMTP_PORT=1025).
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM="Mainframe IT <it@company.local>"
# Base URL of the client app, used to build links in emails (e.g. reset password).
APP_BASE_URL=http://localhost:5173

# Optional — enables auto-extraction of network traffic charts from uploaded images
# (used by POST /api/network/extract-chart). Get a key at https://console.anthropic.com.
ANTHROPIC_API_KEY=
# Override the default model if you want
ANTHROPIC_MODEL=claude-sonnet-4-6

# Optional — UniFi local controller for the Network Monitoring dashboard
# (used by GET /api/network/dashboard). Leave UNIFI_HOST empty to render the
# page with mock data.
#
#   UNIFI_HOST              Controller URL — e.g. https://unifi.local:8443
#                           (classic) or https://192.168.1.1 (UniFi OS / UDM)
#   UNIFI_USERNAME          Local admin username
#   UNIFI_PASSWORD          Local admin password
#   UNIFI_SITE              Site name (default: 'default')
#   UNIFI_OS                'true' for UniFi OS / UDM / Cloud Key Gen2+ —
#                           prefixes API calls with /proxy/network. Leave
#                           empty for a classic controller (:8443) or the
#                           modern self-hosted UniFi Network Server (:8080).
#                           The login endpoint is auto-detected.
#   UNIFI_INSECURE_TLS      'true' to accept the controller's self-signed cert
#   UNIFI_COOKIE            Optional. If set, the backend skips login and
#                           uses this raw Cookie header value for all API
#                           calls. Useful when the admin requires 2FA / SSO
#                           and no local admin / API key is available — copy
#                           the cookie from your logged-in browser session
#                           (DevTools → Application → Cookies). Re-paste
#                           when it expires. When set, UNIFI_USERNAME and
#                           UNIFI_PASSWORD are ignored.
UNIFI_HOST=
UNIFI_USERNAME=
UNIFI_PASSWORD=
UNIFI_SITE=default
UNIFI_OS=
UNIFI_INSECURE_TLS=true
UNIFI_COOKIE=
